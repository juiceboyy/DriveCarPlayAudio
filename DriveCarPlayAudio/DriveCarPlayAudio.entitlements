<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- CarPlay audio entitlement — requires Apple approval for App Store distribution.
       For development/simulator testing this is sufficient. -->
  <key>com.apple.developer.carplay-audio</key>
  <true/>
</dict>
</plist>
